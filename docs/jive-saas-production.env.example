# Copy to /tmp/jive-saas-production.env and fill with real production values.
# Do not commit the filled file.
#
# This file is consumed by scripts/check_saas_production_readiness.sh.
# The readiness gate never prints secret values.

# Required for production app builds.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Production admin/API surface. Use explicit HTTPS origins, never "*".
ADMIN_API_ALLOWED_ORIGINS=
ADMIN_API_TOKEN=
ANALYTICS_ADMIN_TOKEN=
NOTIFICATION_ADMIN_TOKEN=

# Store billing runtime flags for app builds.
# For Google Play distribution, keep domestic providers disabled until
# provider signature verification replaces the staging shared-token webhook.
PAYMENT_CHANNEL=google_play
ENABLE_STORE_BILLING=true
ENABLE_WECHAT_PAY=false
ENABLE_ALIPAY=false

# Google Play billing verification.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Keep embedded newlines escaped as \n on a single line.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_PLAY_PACKAGE_NAME=
PUBSUB_BEARER_TOKEN=
WEBHOOK_HMAC_SECRET=

# Optional iOS production billing verification.
APPLE_APP_STORE_BUNDLE_ID=
APPLE_APP_STORE_SHARED_SECRET=
APPLE_APP_STORE_APPLE_ID=
APPLE_APP_STORE_ENVIRONMENT=production

# Domestic payment production guard.
# Leave mock base URL empty for production.
# Leave domestic providers disabled until provider signature verification lands.
DOMESTIC_PAYMENT_WEBHOOK_TOKEN=
DOMESTIC_PAYMENT_MOCK_BASE_URL=

# AdMob production identifiers for operations tracking.
# The release-candidate lane injects ADMOB_APP_ID into AndroidManifest.xml and
# ADMOB_BANNER_ID into Dart through --dart-define-from-file.
ADMOB_APP_ID=
ADMOB_BANNER_ID=

# Optional Android release signing values for uploading GitHub Actions secrets.
# Prefer setting these directly from a secure local shell when possible.
ANDROID_RELEASE_KEYSTORE_BASE64=
ANDROID_RELEASE_STORE_PASSWORD=
ANDROID_RELEASE_KEY_ALIAS=
ANDROID_RELEASE_KEY_PASSWORD=
