# Copy to /tmp/jive-saas-staging.env and fill with real staging values.
# Do not commit the filled file.
#
# Core SaaS rollout needs only:
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#   ADMIN_API_TOKEN
#   ADMIN_API_ALLOWED_ORIGINS
#   ANALYTICS_ADMIN_TOKEN
#   NOTIFICATION_ADMIN_TOKEN
#
# Billing rollout additionally needs the Google / Apple / webhook variables below.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional until billing rollout.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Keep embedded newlines escaped as \n on a single line.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_PLAY_PACKAGE_NAME=

# Optional until billing rollout.
APPLE_APP_STORE_BUNDLE_ID=
APPLE_APP_STORE_SHARED_SECRET=
APPLE_APP_STORE_APPLE_ID=
APPLE_APP_STORE_ENVIRONMENT=

# Optional until billing rollout.
PUBSUB_BEARER_TOKEN=
WEBHOOK_HMAC_SECRET=

# Required for core SaaS rollout.
ADMIN_API_TOKEN=
ADMIN_API_ALLOWED_ORIGINS=
ANALYTICS_ADMIN_TOKEN=
NOTIFICATION_ADMIN_TOKEN=
